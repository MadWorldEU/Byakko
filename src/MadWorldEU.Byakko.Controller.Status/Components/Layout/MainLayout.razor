@inherits LayoutComponentBase

<div class="d-flex min-vh-100">

    <nav class="status-sidebar d-none d-md-flex flex-column bg-body-tertiary border-end border-body">
        <div class="p-4 border-bottom border-body d-flex align-items-center gap-2">
            <img src="/icons/logo.svg" width="22" height="22" alt="Byakko Status logo" class="flex-shrink-0" />
            <span class="fw-bold fs-5">Byakko Status</span>
        </div>

        <div class="p-3 flex-grow-1 d-flex flex-column gap-1">
            <div class="text-uppercase text-secondary small fw-semibold px-2 mb-1" style="font-size: 0.7rem; letter-spacing: 0.08em">Overview</div>
            <NavLink class="status-nav-link" href="/" Match="NavLinkMatch.All">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M10.854 7.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 9.793l2.646-2.647a.5.5 0 0 1 .708 0"/>
                    <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/>
                </svg>
                Status
            </NavLink>
        </div>
    </nav>

    <div class="flex-grow-1 d-flex flex-column overflow-hidden">
        <header class="d-md-none bg-body-tertiary border-bottom border-body px-3 py-2 d-flex align-items-center gap-2 sticky-top">
            <img src="/icons/logo.svg" width="18" height="18" alt="Byakko Status logo" />
            <span class="fw-semibold">Byakko Status</span>
        </header>

        <main class="flex-grow-1 p-4 overflow-auto">
            @Body
        </main>
    </div>

</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>