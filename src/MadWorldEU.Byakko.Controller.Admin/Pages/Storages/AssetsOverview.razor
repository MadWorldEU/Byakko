@page "/storages/assets"
@attribute [Authorize(Policy = AuthorizationPolicies.Administrator)]
@inject IAssetService AssetService
@inject IJSRuntime JsRuntime

<PageTitle>Assets – Byakko Admin</PageTitle>

<div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Assets</h1>
        <p class="text-secondary mb-0 small">Overview of all uploaded assets, 20 per page.</p>
    </div>
</div>

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
else if (_response is not null)
{
    <div class="mb-3">
        <input type="search"
               class="form-control"
               placeholder="Filter by Asset ID or User ID…"
               @bind="_searchQuery"
               @bind:event="oninput"
               @onkeydown="OnSearchKeyDownAsync" />
    </div>

    <div class="card border-0 bg-body-tertiary">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Asset ID</th>
                        <th>Content Type</th>
                        <th>User ID</th>
                        <th>Created</th>
                        <th>Expires</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var asset in _response.Assets)
                    {
                        <tr>
                            <td>
                                @asset.Name
                                <span class="text-secondary ms-1"
                                      data-bs-toggle="tooltip"
                                      data-bs-placement="top"
                                      data-bs-html="true"
                                      data-bs-custom-class="tooltip-wide"
                                      title="@($"Size: {ByteFormatter.Format(asset.Size)}<br>Updated: {asset.UpdatedAt:yyyy-MM-dd HH:mm}")"
                                      style="cursor: default; display: inline-flex; align-items: center;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                                    </svg>
                                </span>
                            </td>
                            <td class="font-monospace small text-secondary">@asset.Id</td>
                            <td><span class="badge bg-secondary fw-normal">@asset.ContentType</span></td>
                            <td class="font-monospace small text-secondary">@asset.UserId</td>
                            <td class="small">@asset.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="small">@asset.ExpiresAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-end">
                                @if (_confirmingDeleteId != asset.Id)
                                {
                                    <a class="btn btn-sm btn-outline-secondary me-2" href="/audits/@asset.Id">Logs</a>
                                }
                                @if (!asset.IsDeleted)
                                {
                                    @if (_confirmingDeleteId == asset.Id)
                                    {
                                        <span class="small text-warning me-2">Delete content?</span>
                                        <button class="btn btn-sm btn-danger me-1" @onclick="() => ConfirmDeleteAsync(asset.Id)" disabled="@_deleting">Yes</button>
                                        <button class="btn btn-sm btn-outline-secondary me-2" @onclick="CancelDelete" disabled="@_deleting">No</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RequestDelete(asset.Id)">Delete</button>
                                    }
                                }
                            </td>
                        </tr>
                    }
                    @if (_response.Assets.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-secondary py-4">No assets found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
        <span class="text-secondary small">
            @_response.TotalCount total &middot; Page @_currentPage &middot; @_response.PageSize per page
        </span>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" @onclick="PreviousPageAsync" disabled="@(_currentPage <= 1)">Previous</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="NextPageAsync" disabled="@(!_response.HasNextPage)">Next</button>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private GetAssetsMetadataResponse? _response;
    private int _currentPage = 1;
    private Guid? _confirmingDeleteId;
    private bool _deleting;
    private string _searchQuery = string.Empty;

    private Guid? SearchGuid => Guid.TryParse(_searchQuery, out var g) ? g : null;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JsRuntime.InvokeVoidAsync("initTooltips");
    }

    private async Task LoadPageAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var result = await AssetService.GetAssetsMetadataAsync(_currentPage, SearchGuid, SearchGuid);

            if (result.IsSuccess)
            {
                _response = result.Response;
            }
            else
            {
                _error = result.Failure?.Description ?? "An unexpected error occurred.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load assets: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
        {
            return;
        }

        _currentPage = 1;
        await LoadPageAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_currentPage <= 1)
        {
            return;
        }

        _currentPage--;
        await LoadPageAsync();
    }

    private async Task NextPageAsync()
    {
        if (_response?.HasNextPage != true)
        {
            return;
        }

        _currentPage++;
        await LoadPageAsync();
    }

    private void RequestDelete(Guid id)
    {
        _confirmingDeleteId = id;
    }

    private void CancelDelete()
    {
        _confirmingDeleteId = null;
    }

    private async Task ConfirmDeleteAsync(Guid id)
    {
        _deleting = true;
        _error = null;

        try
        {
            await AssetService.DeleteAssetContentAsync(id);
            _confirmingDeleteId = null;
            await LoadPageAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to delete asset content: {ex.Message}";
            _confirmingDeleteId = null;
        }
        finally
        {
            _deleting = false;
        }
    }
}