@page "/"
@inject IStringLocalizer<Resources> Localizer

<PageTitle>@Localizer["Brand Name"] – @Localizer["Home Page Title"]</PageTitle>

<div class="alert alert-warning mb-0 rounded-0 text-center small" role="alert">
    <strong>Beta</strong> — @Localizer["Home Beta Message"]
</div>

<section class="hero-section py-5">
    <div class="container py-lg-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <p class="text-primary fw-semibold text-uppercase letter-spacing-wide mb-2">@Localizer["Home Hero Eyebrow"]</p>
                <h1 class="display-3 fw-bold lh-sm mb-4">
                    @Localizer["Home Hero Title 1"]<br />
                    <span class="hero-gradient-text">@Localizer["Home Hero Title 2"]</span>
                </h1>
                <p class="lead text-secondary mb-4">
                    @Localizer["Home Hero Lead"]
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="/storage/upload" class="btn btn-primary btn-lg px-4 py-2 fw-semibold">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2 mb-1" viewBox="0 0 16 16">
                            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                            <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z"/>
                        </svg>
                        @Localizer["Start Sharing"]
                    </a>
                    <a href="#how-it-works" class="btn btn-outline-secondary btn-lg px-4 py-2">
                        @Localizer["Home See How It Works"]
                    </a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-flex justify-content-center">
                <div class="hero-illustration position-relative">
                    <div class="hero-blob"></div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="220" height="220" fill="currentColor" class="text-primary hero-cloud-icon" viewBox="0 0 16 16">
                        <path d="M4.406 1.342A5.53 5.53 0 0 1 8 0c2.69 0 4.923 2 5.166 4.579C14.758 4.804 16 6.137 16 7.773 16 9.569 14.502 11 12.687 11H10a.5.5 0 0 1 0-1h2.688C13.979 10 15 8.988 15 7.773c0-1.216-1.02-2.228-2.313-2.228h-.5v-.5C12.188 2.825 10.328 1 8 1a4.53 4.53 0 0 0-2.941 1.1c-.757.652-1.153 1.438-1.153 2.055v.448l-.445.049C2.064 4.805 1 5.952 1 7.318 1 8.785 2.23 10 3.781 10H6a.5.5 0 0 1 0 1H3.781C1.708 11 0 9.366 0 7.318c0-1.763 1.266-3.223 2.942-3.593.143-.863.698-1.723 1.464-2.383z"/>
                        <path d="M7.646 15.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 14.293V5.5a.5.5 0 0 0-1 0v8.793l-2.146-2.147a.5.5 0 0 0-.708.708l3 3z"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary border-top border-bottom border-body">
    <div class="container">
        <div class="row g-4 justify-content-center text-center">
            <div class="col-4 col-md-3">
                <div class="fw-bold fs-2 text-primary">@Localizer["Home Stat Fast"]</div>
                <div class="text-secondary small">@Localizer["Home Stat Fast Sub"]</div>
            </div>
            <div class="col-4 col-md-3">
                <div class="fw-bold fs-2 text-primary">@Localizer["Home Stat Secure"]</div>
                <div class="text-secondary small">@Localizer["Home Stat Secure Sub"]</div>
            </div>
            <div class="col-4 col-md-3">
                <div class="fw-bold fs-2 text-primary">@Localizer["Home Stat Simple"]</div>
                <div class="text-secondary small">@Localizer["Home Stat Simple Sub"]</div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-2">@Localizer["Home Features Heading"]</h2>
        <p class="text-center text-secondary mb-5">@Localizer["Home Features Subtitle"]</p>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card card h-100 border-0 bg-body-tertiary p-1">
                    <div class="card-body p-4">
                        <div class="feature-icon bg-primary bg-opacity-10 text-primary rounded-3 mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                                <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z"/>
                            </svg>
                        </div>
                        <h5 class="fw-semibold mb-2">@Localizer["Home Feature 1 Title"]</h5>
                        <p class="text-secondary mb-0">
                            @string.Format(Localizer["Home Feature 1 Text"], Localizer["Brand Name"])
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card card h-100 border-0 bg-body-tertiary p-1">
                    <div class="card-body p-4">
                        <div class="feature-icon bg-primary bg-opacity-10 text-primary rounded-3 mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M13.5 1a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM11 2.5a2.5 2.5 0 1 1 .603 1.628l-6.718 3.12a2.499 2.499 0 0 1 0 1.504l6.718 3.12a2.5 2.5 0 1 1-.488.876l-6.718-3.12a2.5 2.5 0 1 1 0-3.256l6.718-3.12A2.5 2.5 0 0 1 11 2.5zm-8.5 4a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm11 5.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/>
                            </svg>
                        </div>
                        <h5 class="fw-semibold mb-2">@Localizer["Home Feature 2 Title"]</h5>
                        <p class="text-secondary mb-0">
                            @Localizer["Home Feature 2 Text"]
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card card h-100 border-0 bg-body-tertiary p-1">
                    <div class="card-body p-4">
                        <div class="feature-icon bg-primary bg-opacity-10 text-primary rounded-3 mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
                            </svg>
                        </div>
                        <h5 class="fw-semibold mb-2">@Localizer["Home Feature 3 Title"]</h5>
                        <p class="text-secondary mb-0">
                            @Localizer["Home Feature 3 Text"]
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="how-it-works" class="py-5 bg-body-tertiary border-top border-body">
    <div class="container">
        <h2 class="text-center fw-bold mb-2">@Localizer["Home How It Works Heading"]</h2>
        <p class="text-center text-secondary mb-5">@Localizer["Home How It Works Subtitle"]</p>
        <div class="row g-4 justify-content-center">
            <div class="col-sm-6 col-lg-4">
                <div class="d-flex gap-4 align-items-start">
                    <div class="step-number flex-shrink-0">1</div>
                    <div>
                        <h6 class="fw-semibold mb-1">@Localizer["Home Step 1 Title"]</h6>
                        <p class="text-secondary small mb-0">@Localizer["Home Step 1 Text"]</p>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="d-flex gap-4 align-items-start">
                    <div class="step-number flex-shrink-0">2</div>
                    <div>
                        <h6 class="fw-semibold mb-1">@Localizer["Home Step 2 Title"]</h6>
                        <p class="text-secondary small mb-0">@string.Format(Localizer["Home Step 2 Text"], Localizer["Brand Name"])</p>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="d-flex gap-4 align-items-start">
                    <div class="step-number flex-shrink-0">3</div>
                    <div>
                        <h6 class="fw-semibold mb-1">@Localizer["Home Step 3 Title"]</h6>
                        <p class="text-secondary small mb-0">@Localizer["Home Step 3 Text"]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container text-center py-3">
        <h2 class="fw-bold mb-3">@Localizer["Home CTA Heading"]</h2>
        <p class="text-secondary mb-4 col-md-6 mx-auto">
            @string.Format(Localizer["Home CTA Text"], Localizer["Brand Name"])
        </p>
        <a href="/storage/upload" class="btn btn-primary btn-lg px-5 py-3 fw-semibold">
            @Localizer["Home CTA Button"]
        </a>
    </div>
</section>