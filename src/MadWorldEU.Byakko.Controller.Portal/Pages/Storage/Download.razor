@page "/storage/download/{Id}"
@inject IAssetService AssetService
@inject IJSRuntime Js
@inject IStringLocalizer<Resources> Localizer
@implements IAsyncDisposable

<PageTitle>@Localizer["Brand Name"] – @Localizer["Download Page Title"]</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            @if (_isLoading)
            {
                <div class="d-flex justify-content-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">@Localizer["Download Loading"]</span>
                    </div>
                </div>
            }
            else if (_errorMessage is not null)
            {
                <div class="alert alert-danger" role="alert">@_errorMessage</div>
            }
            else if (_metadata is not null)
            {
                <div class="card border-0 bg-body-tertiary">
                    <div class="card-body p-4 d-flex flex-column gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="feature-icon bg-primary bg-opacity-10 text-primary rounded-3 flex-shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M4 0h5.293A1 1 0 0 1 10 .293L13.707 4a1 1 0 0 1 .293.707V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2m5.5 1.5v2a1 1 0 0 0 1 1h2z"/>
                                </svg>
                            </div>
                            <div class="overflow-hidden">
                                <div class="fw-semibold text-truncate">@_metadata.Name</div>
                                <div class="text-secondary small">@_metadata.ContentType</div>
                                @if (IsExpired)
                                {
                                    <div class="text-danger small">@Localizer["Download Expired On"] @_metadata.ExpiresAt.ToString("d MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</div>
                                }
                                else
                                {
                                    <div class="text-secondary small">@Localizer["Download Expires On"] @_metadata.ExpiresAt.ToString("d MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</div>
                                }
                            </div>
                        </div>
                        @if (_downloadError is not null)
                        {
                            <div class="alert alert-danger mb-0" role="alert">@_downloadError</div>
                        }
                        @if (IsExpired)
                        {
                            <div class="alert alert-warning mb-0" role="alert">
                                @Localizer["Download Expired Message"]
                            </div>
                            <button class="btn btn-primary fw-semibold" disabled>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2 mb-1" viewBox="0 0 16 16">
                                    <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                                    <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 1-.708.708z"/>
                                </svg>
                                @Localizer["Download Button"]
                            </button>
                        }
                        else
                        {
                            <div>
                                <label class="form-label small text-secondary mb-1">@Localizer["Download Password Label"]</label>
                                <input type="password"
                                       class="form-control form-control-sm mb-3"
                                       placeholder="@Localizer["Download Password Placeholder"]"
                                       @bind="_password"
                                       disabled="@_isDownloading" />
                            </div>
                            @if (_isDownloading)
                            {
                                <div class="progress mb-3">
                                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                                         role="progressbar"
                                         style="width: @(_downloadProgressPercent > 0 ? _downloadProgressPercent : 100)%"
                                         aria-valuenow="@_downloadProgressPercent"
                                         aria-valuemin="0"
                                         aria-valuemax="100">
                                        @if (_downloadProgressPercent > 0)
                                        {
                                            @($"{_downloadProgressPercent}%")
                                        }
                                    </div>
                                </div>
                            }
                            <button class="btn btn-primary fw-semibold" @onclick="DownloadAsync" disabled="@_isDownloading">
                                @if (_isDownloading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>@Localizer["Download Downloading"]</span>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2 mb-1" viewBox="0 0 16 16">
                                        <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                                        <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 1-.708.708z"/>
                                    </svg>
                                    <span>@Localizer["Download Button"]</span>
                                }
                            </button>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private DotNetObjectReference<Download>? _dotNetRef;

    private GetAssetMetadataResponse? _metadata;
    private bool _isLoading = true;
    private string? _errorMessage;
    private string? _downloadError;
    private string? _password;
    private bool _isDownloading;
    private int _downloadProgressPercent;
    private bool IsExpired => _metadata is not null && _metadata.ExpiresAt < DateTimeOffset.UtcNow;

    protected override async Task OnInitializedAsync()
    {
        if (!Guid.TryParse(Id, out var guid))
        {
            _errorMessage = "Invalid asset ID.";
            _isLoading = false;
            return;
        }

        try
        {
            var result = await AssetService.GetAssetMetadataAsync(guid);

            if (result.IsSuccess)
            {
                _metadata = result.Response;
            }
            else
            {
                _errorMessage = result.Failure?.Description ?? "Could not load file.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Could not load file: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    [JSInvokable]
    public void UpdateProgress(int percent)
    {
        _downloadProgressPercent = percent;
        StateHasChanged();
    }

    private async Task DownloadAsync()
    {
        _isDownloading = true;
        _downloadError = null;
        _downloadProgressPercent = 0;
        _dotNetRef ??= DotNetObjectReference.Create(this);

        try
        {
            var url = AssetService.GetContentUrl(Guid.Parse(Id));
            var error = await Js.InvokeAsync<string?>("downloadFileWithPassword", url, string.IsNullOrEmpty(_password) ? null : _password, _dotNetRef);
            if (error is not null)
            {
                _downloadError = error;
            }
        }
        finally
        {
            _isDownloading = false;
        }
    }

    public ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        return ValueTask.CompletedTask;
    }

}