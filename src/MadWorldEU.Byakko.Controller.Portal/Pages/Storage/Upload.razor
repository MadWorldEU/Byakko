@page "/storage/upload"
@attribute [Authorize(Policy = AuthorizationPolicies.User)]
@inject IAssetService AssetService
@inject IOptions<AssetSettings> AssetSettings

<PageTitle>Byakko – Upload a File</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="fw-bold mb-1">Upload a file</h2>
            <p class="text-secondary mb-4">Pick any file and we'll generate a shareable link for you.</p>

            <UploadLimitsAlert Limits="_limits" />

            @if (_uploadedId is not null)
            {
                <div class="alert alert-success d-flex flex-column gap-2" role="alert">
                    <div class="fw-semibold">File uploaded successfully!</div>
                    <div class="d-flex align-items-center gap-2">
                        <input class="form-control form-control-sm font-monospace" readonly value="@ShareLink" />
                        <button class="btn @(_linkCopied ? "btn-success" : "btn-outline-success") btn-sm text-nowrap" @onclick="CopyLink">
                            @(_linkCopied ? "Copied!" : "Copy link")
                        </button>
                    </div>
                </div>
            }

            @if (_errorMessage is not null)
            {
                <div class="alert alert-danger" role="alert">@_errorMessage</div>
            }

            @if (_uploadedId is null)
            {
                <div class="card border-0 bg-body-tertiary">
                <div class="card-body p-4">
                    <InputFile class="form-control mb-3" OnChange="OnFileSelected" disabled="@_isUploading" />

                    <div class="mb-4">
                        <button type="button" class="btn btn-link btn-sm text-secondary px-0 text-decoration-none" @onclick="ToggleAdvanced">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1 mb-1" viewBox="0 0 16 16">
                                @if (_showAdvanced)
                                {
                                    <path d="M7.646 4.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1-.708.708L8 5.707l-5.646 5.647a.5.5 0 0 1-.708-.708z"/>
                                }
                                else
                                {
                                    <path d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                                }
                            </svg>
                            Advanced options
                        </button>

                        @if (_showAdvanced)
                        {
                            <div class="mt-2">
                                <label class="form-label small text-secondary mb-1">Password (optional)</label>
                                <input type="password"
                                       class="form-control form-control-sm"
                                       placeholder="Leave empty for no password"
                                       @bind="_password"
                                       disabled="@_isUploading" />
                            </div>
                        }
                    </div>

                    @if (_isUploading)
                    {
                        <div class="mb-3">
                            <div class="progress">
                                <div class="progress-bar progress-bar-striped progress-bar-animated"
                                     role="progressbar"
                                     style="width: @(_uploadProgressPercent)%"
                                     aria-valuenow="@_uploadProgressPercent"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                    @(_uploadProgressPercent)%
                                </div>
                            </div>
                        </div>
                    }

                    <button class="btn btn-primary w-100 fw-semibold"
                            @onclick="UploadAsync"
                            disabled="@(_selectedFile is null || _isUploading || FileLimitReached)">
                        @if (_isUploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Uploading…</span>
                        }
                        else
                        {
                            <span>Upload</span>
                        }
                    </button>
                </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private IJSRuntime Js { get; set; } = null!;

    private IBrowserFile? _selectedFile;
    private Guid? _uploadedId;
    private bool _isUploading;
    private string? _errorMessage;
    private int _uploadProgressPercent;
    private GetUserUploadLimitsResponse? _limits;
    private bool _linkCopied;
    private bool _showAdvanced;
    private string? _password;

    private long MaxUploadSizeInBytes => _limits?.MaxUploadSizeInBytes ?? AssetSettings.Value.MaxUploadSizeInBytes;
    private bool FileLimitReached => _limits is not null && _limits.ActiveFiles >= _limits.MaxFiles;

    private string ShareLink => _uploadedId is not null
        ? $"{Navigation.BaseUri}storage/download/{_uploadedId}"
        : string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var result = await AssetService.GetUserUploadLimitsAsync();

        if (result.IsSuccess)
        {
            _limits = result.Response;
        }
    }

    private void ToggleAdvanced() => _showAdvanced = !_showAdvanced;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _uploadedId = null;
        _errorMessage = null;
    }

    private async Task UploadAsync()
    {
        if (_selectedFile is null)
        {
            return;
        }

        _isUploading = true;
        _errorMessage = null;
        _uploadedId = null;
        _uploadProgressPercent = 0;

        try
        {
            var createResult = await AssetService.CreateAssetAsync(new()
            {
                Name = _selectedFile.Name,
                ContentType = _selectedFile.ContentType,
                Size = _selectedFile.Size
            });

            if (!createResult.IsSuccess)
            {
                _errorMessage = createResult.Failure?.Description ?? "Failed to create asset record.";
                return;
            }

            var createResponse = createResult.Response!;

            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: MaxUploadSizeInBytes);
            await using var progressStream = new ProgressStream(stream, _selectedFile.Size, async percent =>
            {
                _uploadProgressPercent = percent;
                await InvokeAsync(StateHasChanged);
            });

            var uploadResult = await AssetService.UploadAssetContentAsync(
                createResponse.Id,
                progressStream,
                _selectedFile.Name,
                _selectedFile.ContentType,
                _password);

            if (!uploadResult.IsSuccess)
            {
                _errorMessage = uploadResult.Failure?.Description ?? "File content upload failed.";
                return;
            }

            _uploadedId = uploadResult.Response!.Id;
            var limitsResult = await AssetService.GetUserUploadLimitsAsync();
            if (limitsResult.IsSuccess)
            {
                _limits = limitsResult.Response;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Upload failed: {ex.Message}";
        }
        finally
        {
            _isUploading = false;
        }
    }

    private async Task CopyLink()
    {
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", ShareLink);
        _linkCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _linkCopied = false;
        StateHasChanged();
    }
}