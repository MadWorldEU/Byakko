@page "/storage/upload"
@attribute [Authorize(Policy = AuthorizationPolicies.User)]
@inject IAssetService AssetService
@inject IOptions<AssetSettings> AssetSettings
@inject IStringLocalizer<Resources> Localizer
@inject IErrorTranslator ErrorTranslator

<PageTitle>@Localizer["Brand Name"] – @Localizer["Upload Page Title"]</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="fw-bold mb-1">@Localizer["Upload Heading"]</h2>
            <p class="text-secondary mb-4">@Localizer["Upload Subtitle"]</p>

            <UploadLimitsAlert Limits="_limits" />

            @if (_uploadedId is not null)
            {
                <div class="alert alert-success d-flex flex-column gap-2" role="alert">
                    <div class="fw-semibold">@Localizer["Upload Success"]</div>
                    <div class="d-flex align-items-center gap-2">
                        <input class="form-control form-control-sm font-monospace" readonly value="@ShareLink" />
                        <button class="btn @(_linkCopied ? "btn-success" : "btn-outline-success") btn-sm text-nowrap" @onclick="CopyLink">
                            @(_linkCopied ? Localizer["Upload Copied"] : Localizer["Upload Copy Link"])
                        </button>
                    </div>
                </div>
            }

            @if (_errorMessage is not null)
            {
                <div class="alert alert-danger" role="alert">@_errorMessage</div>
            }

            @if (_uploadedId is null)
            {
                <div class="card border-0 bg-body-tertiary">
                <div class="card-body p-4">
                    <InputFile class="form-control mb-3" OnChange="OnFileSelected" disabled="@_isUploading" />

                    <div class="mb-4">
                        <button type="button" class="btn btn-link btn-sm text-secondary px-0 text-decoration-none" @onclick="ToggleAdvanced">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1 mb-1" viewBox="0 0 16 16">
                                @if (_showAdvanced)
                                {
                                    <path d="M7.646 4.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1-.708.708L8 5.707l-5.646 5.647a.5.5 0 0 1-.708-.708z"/>
                                }
                                else
                                {
                                    <path d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                                }
                            </svg>
                            @Localizer["Upload Advanced Options"]
                        </button>

                        @if (_showAdvanced)
                        {
                            <div class="mt-2">
                                <label class="form-label small text-secondary mb-1">@Localizer["Upload Password Label"]</label>
                                <div class="input-group input-group-sm">
                                    <input type="@(_showPassword ? "text" : "password")"
                                           class="form-control form-control-sm"
                                           placeholder="@Localizer["Upload Password Placeholder"]"
                                           @bind="_password"
                                           disabled="@_isUploading" />
                                    <button type="button" class="btn btn-outline-secondary" title="@(_showPassword ? Localizer["Upload Hide Password"] : Localizer["Upload Show Password"])" @onclick="() => _showPassword = !_showPassword">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                            @if (_showPassword)
                                            {
                                                <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z"/>
                                                <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829"/>
                                                <path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12z"/>
                                            }
                                            else
                                            {
                                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z"/>
                                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0"/>
                                            }
                                        </svg>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GeneratePassword" disabled="@_isUploading">
                                        @Localizer["Upload Generate"]
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    @if (_isUploading)
                    {
                        <div class="mb-3">
                            <div class="progress">
                                <div class="progress-bar progress-bar-striped progress-bar-animated"
                                     role="progressbar"
                                     style="width: @(_uploadProgressPercent)%"
                                     aria-valuenow="@_uploadProgressPercent"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                    @(_uploadProgressPercent)%
                                </div>
                            </div>
                        </div>
                    }

                    <button class="btn btn-primary w-100 fw-semibold"
                            @onclick="UploadAsync"
                            disabled="@(_selectedFile is null || _isUploading || FileLimitReached)">
                        @if (_isUploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>@Localizer["Upload Uploading"]</span>
                        }
                        else
                        {
                            <span>@Localizer["Upload Button"]</span>
                        }
                    </button>
                </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private IJSRuntime JsRuntime { get; set; } = null!;

    private IBrowserFile? _selectedFile;
    private Guid? _uploadedId;
    private bool _isUploading;
    private string? _errorMessage;
    private int _uploadProgressPercent;
    private GetUserUploadLimitsResponse? _limits;
    private bool _linkCopied;
    private bool _showAdvanced;
    private bool _showPassword;
    private string? _password;

    private long MaxUploadSizeInBytes => _limits?.MaxUploadSizeInBytes ?? AssetSettings.Value.MaxUploadSizeInBytes;
    private bool FileLimitReached => _limits is not null && _limits.ActiveFiles >= _limits.MaxFiles;

    private string ShareLink => _uploadedId is not null
        ? $"{Navigation.BaseUri}storage/download/{_uploadedId}"
        : string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var result = await AssetService.GetUserUploadLimitsAsync();

        if (result.IsSuccess)
        {
            _limits = result.Response;
        }
    }

    private void ToggleAdvanced() => _showAdvanced = !_showAdvanced;

    private void GeneratePassword()
    {
        _password = GeneratePasswordUseCase.Execute();
        _showPassword = true;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _uploadedId = null;
        _errorMessage = null;
    }

    private async Task UploadAsync()
    {
        if (_selectedFile is null)
        {
            return;
        }

        _isUploading = true;
        _errorMessage = null;
        _uploadedId = null;
        _uploadProgressPercent = 0;

        try
        {
            var createResult = await AssetService.CreateAssetAsync(new()
            {
                Name = _selectedFile.Name,
                ContentType = _selectedFile.ContentType,
                Size = _selectedFile.Size
            });

            if (!createResult.IsSuccess)
            {
                _errorMessage = ErrorTranslator.Translate(createResult.Failure!);
                return;
            }

            var createResponse = createResult.Response!;

            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: MaxUploadSizeInBytes);
            await using var progressStream = new ProgressStream(stream, _selectedFile.Size, async percent =>
            {
                _uploadProgressPercent = percent;
                await InvokeAsync(StateHasChanged);
            });

            var uploadResult = await AssetService.UploadAssetContentAsync(
                createResponse.Id,
                progressStream,
                _selectedFile.Name,
                _selectedFile.ContentType,
                _password);

            if (!uploadResult.IsSuccess)
            {
                _errorMessage = ErrorTranslator.Translate(uploadResult.Failure!);
                return;
            }

            _uploadedId = uploadResult.Response!.Id;
            var limitsResult = await AssetService.GetUserUploadLimitsAsync();
            if (limitsResult.IsSuccess)
            {
                _limits = limitsResult.Response;
            }
        }
        catch (Exception ex)
        {
            await JsRuntime.InvokeVoidAsync("console.error", ex.ToString());
            _errorMessage = ErrorTranslator.Translate(BlazorErrors.FileUploadFailed.Code, BlazorErrors.FileUploadFailed.Description);
        }
        finally
        {
            _isUploading = false;
        }
    }

    private async Task CopyLink()
    {
        await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", ShareLink);
        _linkCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _linkCopied = false;
        StateHasChanged();
    }
}