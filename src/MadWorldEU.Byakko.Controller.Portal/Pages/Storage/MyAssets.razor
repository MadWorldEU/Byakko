@page "/storage/my-assets"
@attribute [Authorize(Policy = AuthorizationPolicies.User)]
@inject IAssetService AssetService
@inject IJSRuntime JsRuntime
@inject IStringLocalizer<Resources> Localizer

<PageTitle>@Localizer["Brand Name"] – My Files</PageTitle>

<div class="container py-5">
    <h2 class="fw-bold mb-1">My files</h2>
    <p class="text-secondary mb-4">An overview of all files you have uploaded.</p>

    <UploadLimitsAlert Limits="_limits" />

    @if (_isLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading…</span>
            </div>
        </div>
    }
    else if (_errorMessage is not null)
    {
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    }
    else if (_response is not null)
    {
        @if (_response.Assets.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                You have not uploaded any files yet. <a href="/storage/upload" class="alert-link">Upload your first file.</a>
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (var asset in _response.Assets)
                {
                    var isActive = !asset.IsDeleted && asset.ExpiresAt >= DateTimeOffset.UtcNow;
                    <div class="list-group-item p-3">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div class="flex-grow-1" style="min-width:0">
                                <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                    <span class="fw-medium text-truncate"
                                      data-bs-toggle="tooltip"
                                      data-bs-placement="top"
                                      title="@asset.Name">@asset.Name</span>
                                    @if (asset.IsDeleted)
                                    {
                                        <span class="badge text-bg-secondary">Deleted</span>
                                    }
                                    else if (asset.ExpiresAt < DateTimeOffset.UtcNow)
                                    {
                                        <span class="badge text-bg-warning">Expired</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">Active</span>
                                    }
                                </div>
                                <div class="text-secondary small">
                                    @ByteFormatter.Format(asset.Size) &middot; Expires @asset.ExpiresAt.ToString("d MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)
                                </div>
                            </div>
                            @if (isActive && _confirmingDeleteId != asset.Id)
                            {
                                <div class="d-flex gap-2 flex-shrink-0">
                                    <a class="btn btn-outline-primary btn-sm" href="/storage/download/@asset.Id">Download</a>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RequestDelete(asset.Id)">Delete</button>
                                </div>
                            }
                        </div>
                        @if (isActive && _confirmingDeleteId == asset.Id)
                        {
                            <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
                                <span class="small text-warning">Delete content?</span>
                                <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDeleteAsync(asset.Id)" disabled="@_deleting">Yes</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelDelete" disabled="@_deleting">No</button>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3">
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="PreviousPage"
                        disabled="@(_page <= 1)">
                    Previous
                </button>
                <span class="text-secondary small">Page @_page</span>
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="NextPage"
                        disabled="@(!_response.HasNextPage)">
                    Next
                </button>
            </div>
        }
    }
</div>

@code {
    private GetAssetsMetadataResponse? _response;
    private GetUserUploadLimitsResponse? _limits;
    private bool _isLoading = true;
    private string? _errorMessage;
    private int _page = 1;
    private Guid? _confirmingDeleteId;
    private bool _deleting;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JsRuntime.InvokeVoidAsync("initTooltips");
    }

    private async Task PreviousPage()
    {
        _page--;
        await LoadAsync();
    }

    private async Task NextPage()
    {
        _page++;
        await LoadAsync();
    }

    private void RequestDelete(Guid id)
    {
        _confirmingDeleteId = id;
    }

    private void CancelDelete()
    {
        _confirmingDeleteId = null;
    }

    private async Task ConfirmDeleteAsync(Guid id)
    {
        _deleting = true;
        _errorMessage = null;

        try
        {
            var result = await AssetService.DeleteMyAssetContentAsync(id);
            _confirmingDeleteId = null;

            if (result.IsSuccess)
            {
                await LoadAsync();
            }
            else
            {
                _errorMessage = result.Failure?.Description ?? "An unexpected error occurred.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to delete file: {ex.Message}";
            _confirmingDeleteId = null;
        }
        finally
        {
            _deleting = false;
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            if (_page == 1)
            {
                var limitsResult = await AssetService.GetUserUploadLimitsAsync();
                if (limitsResult.IsSuccess)
                {
                    _limits = limitsResult.Response;
                }
            }

            var assetsResult = await AssetService.GetMyAssetsMetadataAsync(_page);
            if (assetsResult.IsSuccess)
            {
                _response = assetsResult.Response;
            }
            else
            {
                _errorMessage = assetsResult.Failure?.Description ?? "An unexpected error occurred.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Could not load files: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}