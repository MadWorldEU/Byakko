@page "/user-agreement"
@inject IStringLocalizer<Resources> Localizer

<PageTitle>@Localizer["Brand Name"] – @Localizer["UA Page Title"]</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="fw-bold mb-1">@Localizer["UA Heading"]</h1>
            <p class="text-secondary mb-5">@Localizer["UA Last Updated"] <time datetime="2026-06-16">@Localizer["UA Last Updated Date"]</time></p>

            <section class="mb-5">
                <h2 class="h4 fw-semibold mb-3">@Localizer["UA S1 Title"]</h2>
                <p class="text-secondary">
                    @string.Format(Localizer["UA S1 Text"], Localizer["Brand Name"])
                </p>
            </section>

            <section class="mb-5">
                <h2 class="h4 fw-semibold mb-3">@Localizer["UA S2 Title"]</h2>
                <p class="text-secondary">
                    @string.Format(Localizer["UA S2 Text"], Localizer["Brand Name"])
                </p>
            </section>

            <section class="mb-5">
                <h2 class="h4 fw-semibold mb-3">@Localizer["UA S3 Title"]</h2>
                <p class="text-secondary">
                    @string.Format(Localizer["UA S3 Text"], Localizer["Brand Name"])
                </p>
            </section>

            <section class="mb-5">
                <h2 class="h4 fw-semibold mb-3">@Localizer["UA S4 Title"]</h2>
                <p class="text-secondary">
                    @Localizer["UA S4 Intro"]
                </p>
                <ul class="text-secondary">
                    <li>@Localizer["UA S4 Item 1"]</li>
                    <li>@Localizer["UA S4 Item 2"]</li>
                    <li>@Localizer["UA S4 Item 3"]</li>
                    <li>@Localizer["UA S4 Item 4"]</li>
                    <li>@Localizer["UA S4 Item 5"]</li>
                </ul>
                <p class="text-secondary">
                    @Localizer["UA S4 Outro"]
                </p>
            </section>

            <section class="mb-5">
                <h2 class="h4 fw-semibold mb-3">@Localizer["UA S5 Title"]</h2>
                <p class="text-secondary">
                    @((MarkupString)Localizer["UA S5 Text 1"].Value)
                </p>
                <p class="text-secondary">
                    @Localizer["UA S5 Text 2"]
                </p>
            </section>

            <section class="mb-5">
                <h2 class="h4 fw-semibold mb-3">@Localizer["UA S6 Title"]</h2>
                <p class="text-secondary">
                    @Localizer["UA S6 Intro"]
                </p>
                <ul class="text-secondary">
                    <li>@Localizer["UA S6 Item 1"]</li>
                    <li>@Localizer["UA S6 Item 2"]</li>
                    <li>@Localizer["UA S6 Item 3"]</li>
                    <li>@Localizer["UA S6 Item 4"]</li>
                </ul>
                <p class="text-secondary">
                    @Localizer["UA S6 Outro"]
                </p>
            </section>

            <section class="mb-5">
                <h2 class="h4 fw-semibold mb-3">@Localizer["UA S7 Title"]</h2>
                <p class="text-secondary">
                    @string.Format(Localizer["UA S7 Text"], Localizer["Brand Name"])
                </p>
            </section>

            <section class="mb-5">
                <h2 class="h4 fw-semibold mb-3">@Localizer["UA S8 Title"]</h2>
                <p class="text-secondary">
                    @Localizer["UA S8 Text 1"]
                </p>
                <p class="text-secondary">
                    @Localizer["UA S8 Text 2"]
                </p>
            </section>

            <section class="mb-5">
                <h2 class="h4 fw-semibold mb-3">@Localizer["UA S9 Title"]</h2>
                <p class="text-secondary">
                    @Localizer["UA S9 Text Before"]
                    <a href="mailto:info@mad-world.eu">info@mad-world.eu</a>
                </p>
            </section>
        </div>
    </div>
</div>