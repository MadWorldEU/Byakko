@page "/not-found"
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Brand Name"] – @Localizer["NotFound Page Title"]</PageTitle>

<div class="d-flex flex-column align-items-center justify-content-center text-center py-5">
    <h1 class="h3 fw-bold mb-2">@Localizer["NotFound Heading"]</h1>
    <p class="text-secondary mb-4">@Localizer["NotFound Message"]</p>
    <a href="/" class="btn btn-primary">@Localizer["Go To Home"]</a>
</div>