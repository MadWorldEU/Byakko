@page "/Development/TestPage"
@inject IHttpClientFactory HttpClientFactory
@attribute [AllowAnonymous]

<h1 class="mb-4">Test Page</h1>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <h5 class="card-title">Ping</h5>
        <button class="btn btn-primary" @onclick="PingAsync" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            Send Ping
        </button>
        @if (_responsePing is not null)
        {
            <div class="alert alert-success mt-3 mb-0">@_responsePing</div>
        }
    </div>
</div>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <h5 class="card-title">Is authenticated in api?</h5>
        <button class="btn btn-primary" @onclick="IsAuthenticatedAsync" disabled="@(_loading || !_isAuthenticated)">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            Check if user is authenticated in api
        </button>
        @if (!_isAuthenticated)
        {
            <div class="alert alert-warning mt-3 mb-0">Login required</div>
        }
        @if (_responseIsAuthenticated is not null)
        {
            <div class="alert alert-success mt-3 mb-0">@_responseIsAuthenticated</div>
        }
    </div>
</div>

<div class="test-div">
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationState { get; set; } = default!;

    private string? _responsePing;
    private string? _responseIsAuthenticated;
    private bool _loading;
    private bool _isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthenticationState;
        _isAuthenticated = state.User.Identity?.IsAuthenticated ?? false;
    }

    private async Task PingAsync()
    {
        _loading = true;
        _responsePing = null;

        var client = HttpClientFactory.CreateClient(HttpClients.ApiAnonymous);
        _responsePing = await client.GetStringAsync("/tests/ping");

        _loading = false;
    }
    
    private async Task IsAuthenticatedAsync()
    {
        _loading = true;
        _responseIsAuthenticated = null;

        var client = HttpClientFactory.CreateClient(HttpClients.ApiAuthorized);
        _responseIsAuthenticated = await client.GetStringAsync("/tests/isauthenticated");

        _loading = false;
    }
}