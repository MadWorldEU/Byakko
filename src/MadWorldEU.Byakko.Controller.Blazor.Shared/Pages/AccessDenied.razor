@page "/access-denied"
@attribute [AllowAnonymous]
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Brand Name"] – @Localizer["AccessDenied Page Title"]</PageTitle>

<div class="d-flex flex-column align-items-center justify-content-center text-center py-5">
    <h1 class="h3 fw-bold mb-2">@Localizer["AccessDenied Heading"]</h1>
    <p class="text-secondary mb-3">@Localizer["AccessDenied Message"]</p>
    <p class="text-secondary mb-4 small">@Localizer["AccessDenied Detail"]</p>
    <a href="/" class="btn btn-primary">@Localizer["Go To Home"]</a>
</div>